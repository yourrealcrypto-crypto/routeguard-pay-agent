{
  "name": "routeguard-pay-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Policy-gated logistics procurement agent on Hedera. The LLM proposes. Policy decides. Hedera proves.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server/server.js",
    "demo": "tsx src/cli/demo.ts",
    "agent": "tsx src/cli/agent-chat.ts",
    "create:hcs-topic": "tsx scripts/create-hcs-topic.ts",
    "check:account": "tsx scripts/check-account.ts",
    "smoke:testnet": "tsx scripts/live-smoke-test.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hashgraph/hedera-agent-kit": "4.0.0",
    "@hiero-ledger/sdk": "2.85.0",
    "@langchain/core": "0.3.78",
    "@langchain/openai": "0.6.16",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.23",
    "@types/node": "22.18.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
