# ---------------------------------------------------------------------------
# RouteGuard Pay Agent — environment template
# Copy to .env (or .env.local). The app runs with ZERO config in simulation
# mode; fill the Hedera section only when you want real testnet payments.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# --- LLM (optional) --------------------------------------------------------
# With no key, the agent uses a deterministic heuristic so the demo always runs.
# Any OpenAI-compatible endpoint works (set LLM_BASE_URL for a proxy/other provider).
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# --- Hedera (testnet only) -------------------------------------------------
# Leave blank to stay in simulation mode. Get testnet creds at https://portal.hedera.com
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=
HEDERA_VENDOR_ACCOUNT_ID=0.0.yyyyy
HCS_AUDIT_TOPIC_ID=0.0.zzzzz
HEDERA_MIRROR_BASE_URL=https://testnet.mirrornode.hedera.com

# --- Safety switches -------------------------------------------------------
# Master kill switch. Must be true AND operator+vendor set for any real payment.
LIVE_TESTNET_PAYMENTS_ENABLED=false

# --- Policy values (tinybars; 1 HBAR = 100,000,000 tinybars) ---------------
CATALOG_PRICE_TINYBARS=5000000
MAX_PER_PURCHASE_TINYBARS=10000000
AUTO_APPROVE_AT_OR_BELOW_TINYBARS=5000000
DAILY_BUDGET_TINYBARS=20000000

# --- Public-demo rate limits ----------------------------------------------
PUBLIC_LIVE_PURCHASES_PER_IP_PER_HOUR=2
PUBLIC_GLOBAL_LIVE_PURCHASES_PER_DAY=25

# --- Misc ------------------------------------------------------------------
FEEDBACK_URL=https://github.com/hashgraph/hedera-agent-kit/issues/new?title=RouteGuard%20Pay%20Agent%20feedback
LOG_LEVEL=info
